# Which CLIs from CLI-monorepo to install on this instance, comma-separated
# crate names. Editing this requires a rebuild (docker compose build) and a
# restart — there's no hot-add, this is a maintainer decision, not Mercury's.
# Installation (this list) and activation (below) are two separate steps: a
# binary listed here still won't be usable by the model unless a matching,
# schema-valid config file also exists in MERCURY_CLI_CONFIG_DIR.
MERCURY_CLIS=jira,bitbucket,google-chat

# Directory holding one maintainer-authored <binary>.json config per active
# CLI (allowed commands, optional confirm gating, optional minVersion) — see
# cli-configs/jira.json for the reference example. Read at container
# startup, not baked into the image: editing a file here only needs a
# restart, no rebuild. Default matches the bind mount in
# docker-compose.override.yml.
MERCURY_CLI_CONFIG_DIR=/app/cli-config

# Ollama-compatible endpoint (D-02) — never hardcoded in the code.
# Default for development on this machine (macOS + Docker Desktop, local Ollama):
OLLAMA_HOST=http://host.docker.internal:11434

# Which model to request from the endpoint above — never hardcoded either,
# since the production target (a larger model) can't run on every dev machine.
# Suggested default for this machine (already pulled locally):
OLLAMA_MODEL=qwen3:14b

QDRANT_URL=http://qdrant:6333

# Jira (REST API + webhooks, D-03)
JIRA_BASE_URL=
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Google Chat (D-04)
GOOGLE_CHAT_CREDENTIALS_PATH=

# Pub/Sub topic backing the Google Chat channel (full resource name,
# "projects/<project>/topics/<topic>"). Leave empty to disable the channel
# entirely — Mercury then only runs the terminal channel.
GOOGLE_CHAT_PUBSUB_TOPIC=

# Comma-separated space names/ids Mercury joins once at startup (bare id or
# full "spaces/{id}" resource name, e.g. "spaces/AAQAtCLmaho"). No auto-
# discovery: Mercury only ever participates in spaces listed here, or ones
# explicitly joined mid-conversation via the joinSpace tool.
GOOGLE_CHAT_SPACES=

# GitHub API (Extension Capability Loop, D-12/D-29)
GITHUB_TOKEN=
